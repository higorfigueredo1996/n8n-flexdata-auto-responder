# .env.example
# Copie este arquivo para .env e preencha com seus valores reais
# IMPORTANTE: Nunca commit .env em repositórios públicos!

# ============================================
# GROQ API
# ============================================
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=gsk_seu_api_key_aqui_copie_do_console

# Modelo Groq (não mude a menos que use outro modelo)
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================
# N8N
# ============================================
# URL do seu N8N (local ou cloud)
N8N_URL=https://seu-instance.n8n.cloud
N8N_WEBHOOK_URL=https://seu-instance.n8n.cloud/webhook/flexdata

# ============================================
# MICROSOFT OUTLOOK
# ============================================
# Suas credenciais do Outlook (configuradas no N8N)
OUTLOOK_EMAIL=seu_email@outlook.com
OUTLOOK_ACCOUNT_ID=seu-account-id-aqui

# ============================================
# FLEXDATA (Configuração da Empresa)
# ============================================
# Nome da empresa (para o prompt)
COMPANY_NAME=FlexData

# Email de suporte (para resposta fora de FAQ)
SUPPORT_EMAIL=support@flexdata.com.br

# Telefone de contato
SUPPORT_PHONE=(11) 4000-1234

# ============================================
# PARÂMETROS DE IA
# ============================================
# Temperature controla criatividade da resposta
# 0.0-0.3: Muito consistente (às vezes robótico)
# 0.7: IDEAL para FAQ (consistente + natural)
# 0.9-1.0: Criativo demais (pode errar em FAQ)
AI_TEMPERATURE=0.7

# Máximo de tokens na resposta
# 500 é suficiente para FAQs
AI_MAX_TOKENS=500

# Timeout em segundos para resposta da IA
AI_TIMEOUT=30

# ============================================
# LOGGING & DEBUG
# ============================================
# Nível de log
LOG_LEVEL=info

# Salvar logs em arquivo?
LOG_TO_FILE=true

# Caminho do arquivo de log
LOG_FILE_PATH=./logs/n8n-automation.log

# ============================================
# MODO DE TESTE
# ============================================
# Ativar modo test? (não envia emails reais)
TEST_MODE=false

# Email para testes (ao invés do remetente real)
TEST_EMAIL=seu_email_teste@example.com

# ============================================
# NOTIFICAÇÕES
# ============================================
# Notificar quando houver erro?
NOTIFY_ON_ERROR=true

# Email para notificações de erro
ERROR_NOTIFICATION_EMAIL=admin@flexdata.com.br

# ============================================
# RATE LIMITING
# ============================================
# Máximo de requisições por minuto
MAX_REQUESTS_PER_MINUTE=60

# Tempo de espera entre requisições (ms)
REQUEST_DELAY_MS=0

# ============================================
# CACHE
# ============================================
# Usar cache de respostas?
USE_CACHE=false

# TTL do cache em minutos
CACHE_TTL_MINUTES=60

# ============================================
# MÉTRICAS
# ============================================
# Coletar métricas?
COLLECT_METRICS=true

# Enviar métricas para serviço externo?
SEND_METRICS_EXTERNAL=false

# URL do serviço de métricas
METRICS_SERVICE_URL=https://metrics.example.com

# ============================================
# SEGURANÇA
# ============================================
# Validar domínio de email?
VALIDATE_EMAIL_DOMAIN=true

# Domínios permitidos (separados por vírgula)
ALLOWED_EMAIL_DOMAINS=flexdata.com.br,flexdata.com

# Obscurecer email na resposta?
OBSCURE_EMAIL_IN_LOGS=true

# ============================================
# DESENVOLVIMENTO
# ============================================
# Usar ambiente de desenvolvimento?
DEV_MODE=false

# Tempo de delay para desenvolvimento (ms)
DEV_DELAY_MS=1000

# ============================================
# NOTAS
# ============================================
# 
# 1. NUNCA compartilhe este arquivo com credenciais reais
# 2. Use 'cp .env.example .env' para começar
# 3. Atualize .env com seus valores
# 4. .env é ignorado pelo .gitignore (segurança)
# 5. Para produção, use variáveis de ambiente do sistema
#
